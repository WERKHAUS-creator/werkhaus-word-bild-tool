{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "noEmitOnError": true,
    "outDir": "lib",
    "sourceMap": true,
    "target": "es2017",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["dom", "es2017"],
    "types": ["office-js"],
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0"
  },
  "exclude": ["node_modules", "dist", "lib", "lib-amd"],
  "ts-node": {
    "files": true
  }
}
